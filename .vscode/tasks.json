{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "1: Build all subprojects in release config",
            "type": "shell",
            "command": "make CONFIG=RELEASE",
            "problemMatcher": []
        },
        {
            "label": "2: Build all subprojects in debug config",
            "type": "shell",
            "command": "make CONFIG=DEBUG",
            "problemMatcher": []
        },
        {
            "label": "3: Clean all subprojects (remove all generated files)",
            "type": "shell",
            "command": "make",
            "args": [
                "clean"
            ],
            "problemMatcher": []
        },
        {
            "label": "4: Reset all subprojects (clean PLUS remove downloaded files)",
            "type": "shell",
            "command": "make",
            "args": [
                "reset"
            ],
            "problemMatcher": []
        },
        {
            "label": "5: Reconnect to target",
            "command": "${workspaceFolder}/scripts/task_reconnect_target.sh",
            "type": "shell",
            "problemMatcher": {
                "owner": "batch",
                "fileLocation": [
                    "absolute"
                ],
                "pattern": [
                    {
                        "regexp": "^(.*):(\\d+):(.*):FAIL:(.*)$",
                        "file": 1,
                        "line": 2,
                        "message": 4
                    }
                ]
            }
        }
    ]
}